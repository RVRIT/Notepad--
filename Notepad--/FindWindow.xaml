<Window x:Class="Notepad.FindWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find" Height="120" Width="350"
        ResizeMode="NoResize">
    <StackPanel Margin="10">
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Find:" Width="50" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchBox" />
        </DockPanel>
        <DockPanel>
            <CheckBox x:Name="AllTabsBox" Content="All tabs" Width="80"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                
                <Button Content="Find Prev" Width="70" Margin="0,0,8,0" Click="FindPrevious_Click"/>
                <Button Content="Find" Width="70" Margin="0,0,8,0" Click="Find_Click"/>
                <Button Content="Find Next" Width="70" Margin="0,0,8,0" Click="Find_Click"/>
                
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>