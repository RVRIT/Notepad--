<Window x:Class="Notepad.ReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace" Height="160" Width="350"
        ResizeMode="NoResize">
    <StackPanel Margin="10">
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Find:" Width="60" VerticalAlignment="Center"/>
            <TextBox x:Name="SearchBox"/>
        </DockPanel>
        <DockPanel Margin="0,0,0,8">
            <TextBlock Text="Replace:" Width="60" VerticalAlignment="Center"/>
            <TextBox x:Name="ReplaceBox"/>
        </DockPanel>
        <DockPanel>
            <CheckBox x:Name="AllTabsBox" Content="All tabs" Width="80" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Replace" Width="70" Margin="0,0,8,0" Click="Replace_Click"/>
                <Button Content="Replace All" Width="80" Margin="0,0,8,0" Click="ReplaceAll_Click"/>    
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>